# Security configurations
prefer-offline=true
package-import-method=hardlink

# Audit configuration
audit-level=moderate

# Security: Enable strict SSL and registry verification
strict-ssl=true

# Fetch configuration
fetch-timeout=60000
fetch-retries=2

# Additional security settings
ignore-scripts=false
fund=false

# Package age restriction is configured in pnpm-workspace.yaml

link-workspace-packages=deep