{
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "version": "0.0.1",
  "description": "Monorepo for ZeroDev Signer SDK",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive run build",
    "dev": "pnpm --recursive run dev",
    "typecheck": "pnpm --recursive run typecheck",
    "clean": "pnpm --recursive run clean",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "ci": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config e2e/vitest.integration.config.ts",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "changeset:release": "pnpm build && bash scripts/remove-type.sh && changeset publish && bash scripts/restore-type.sh && pnpm format"
  },
  "keywords": [
    "monorepo",
    "wallet",
    "offchainlabs",
    "zerodev",
    "wallet",
    "signer",
    "viem",
    "account-abstraction",
    "eip7702"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@playwright/test": "^1.52.0",
    "@changesets/cli": "^2.29.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "typescript": "~5.9.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --files-ignore-unknown=true --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
