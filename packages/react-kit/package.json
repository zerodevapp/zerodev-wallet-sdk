{
  "name": "@zerodev/wallet-react-kit",
  "version": "0.0.1",
  "description": "React UI components for ZeroDev Wallet SDK",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/_cjs/index.js",
  "module": "./dist/_esm/index.js",
  "types": "./dist/_types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/_types/index.d.ts",
      "import": "./dist/_esm/index.js",
      "require": "./dist/_cjs/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "!dist/_esm/**/*.tsbuildinfo",
    "!dist/_cjs/**/*.tsbuildinfo",
    "!dist/_types/**/*.tsbuildinfo",
    "!.env",
    "!./**/*.test.ts",
    "!./**/*.test.tsx",
    "!./**/*.stories.ts",
    "!./**/*.stories.tsx",
    "!.changeset"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run build:css && pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
    "build:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:cjs": "tsc --project ./tsconfig.build.json --module commonjs --moduleResolution node --outDir ./dist/_cjs --removeComments --verbatimModuleSyntax false && printf '{\"type\":\"commonjs\"}' > ./dist/_cjs/package.json",
    "build:esm": "tsc --project ./tsconfig.build.json --outDir ./dist/_esm && printf '{\"type\": \"module\",\"sideEffects\":false}' > ./dist/_esm/package.json",
    "build:types": "tsc --project ./tsconfig.build.json --outDir ./dist/_types --emitDeclarationOnly --declaration --declarationMap",
    "dev": "tsc --watch",
    "dev:css": "npx @tailwindcss/cli -i ./src/styles.css -o ./dist/styles.css --watch",
    "typecheck": "tsc --noEmit --project ./tsconfig.build.json",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "wallet",
    "zerodev",
    "web3"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@zerodev/wallet-core": "workspace:*",
    "@zerodev/wallet-react": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "storybook": "^10.3.3",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3"
  },
  "type": "module",
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  }
}
