{
  "extends": "./templates/typescript/tsconfig.base.json",
  "include": [
    "packages/core/src/**/*.ts",
    "packages/react/src/**/*.ts",
    "packages/wallet-react-ui/src/**/*.ts",
    "packages/wallet-react-ui/src/**/*.tsx"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vitest/globals"]
  }
}
